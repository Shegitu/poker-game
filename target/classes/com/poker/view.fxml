<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.poker.Controller">

    <top>
        <Label text="♠ SIMPLE POKER GAME ♣"
               style="-fx-font-size: 28px;
                      -fx-font-weight: bold;
                      -fx-padding: 20;" />
    </top>

    <center>
        <VBox spacing="25" alignment="CENTER">

            <!-- Player Cards -->
            <VBox spacing="10" alignment="CENTER">
                <Label text="Player Cards"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;" />

                <HBox fx:id="playerCardsBox"
                      spacing="10"
                      alignment="CENTER"/>
            </VBox>

            <!-- Computer Cards -->
            <VBox spacing="10" alignment="CENTER">
                <Label text="Computer Cards"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;" />

                <HBox fx:id="computerCardsBox"
                      spacing="10"
                      alignment="CENTER"/>
            </VBox>

            <!-- Result -->
            <Label fx:id="resultLabel"
                   text="Press Deal Cards to Start"
                   style="-fx-font-size: 18px;
                          -fx-font-weight: bold;" />

            <!-- Score Counter -->
            <Label fx:id="scoreLabel"
                   text="Player: 0 | Computer: 0"
                   style="-fx-font-size: 18px;
                          -fx-font-weight: bold;" />

            <!-- Buttons -->
            <HBox spacing="20" alignment="CENTER">

                <Button text="Deal Cards"
                        onAction="#dealCards"
                        style="-fx-font-size: 18px;
                               -fx-padding: 10 20;" />

                <Button text="Restart Game"
                        onAction="#restartGame"
                        style="-fx-font-size: 18px;
                               -fx-padding: 10 20;" />

            </HBox>

        </VBox>
    </center>

</BorderPane>